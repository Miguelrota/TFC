# Archivo de ejemplo para configuración de base de datos
# Copia este archivo como '.env' e introduce tus credenciales reales

# Credenciales de conexión a la Base de Datos
DB_USER=mi_usuario_ficticio
DB_PASSWORD=mi_password_secreta
DB_SERVER=servidor_sql_test
DB_NAME=GestionFormacion_Test
DB_PORT=1433
DB_TRUST_SERVER_CERTIFICATE=true

# Credenciales para el servicio de OCR (Mindee u otros si se integran)
MINDEE_API_KEY=tu_api_key_de_mindee_aqui
